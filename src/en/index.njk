---
layout: base.njk
title: Club Management
description: The smart club management for shooting clubs.
lang: en
---
<div class="hero-section text-center">
    <div class="container">
        <h1 class="display-4 fw-bold mb-4">{{ translations[lang].heroTitle }}</h1>
        <p class="lead mb-5 text-muted">{{ translations[lang].heroSubtitle }}</p>
        <a href="/{{ lang }}/contact/" class="btn btn-primary btn-lg rounded-pill px-5">{{ translations[lang].cta }}</a>
    </div>
</div>

<div class="container py-5">
    <div class="row g-4 py-5 row-cols-1 row-cols-lg-3">
        <div class="col text-center">
            <div class="feature-icon mx-auto">👥</div>
            <h3 class="fs-4">{{ translations[lang].feature1Title }}</h3>
            <p class="text-muted">{{ translations[lang].feature1Desc }}</p>
        </div>
        <div class="col text-center">
            <div class="feature-icon mx-auto">📋</div>
            <h3 class="fs-4">{{ translations[lang].feature2Title }}</h3>
            <p class="text-muted">{{ translations[lang].feature2Desc }}</p>
        </div>
        <div class="col text-center">
            <div class="feature-icon mx-auto">🎯</div>
            <h3 class="fs-4">{{ translations[lang].feature3Title }}</h3>
            <p class="text-muted">{{ translations[lang].feature3Desc }}</p>
        </div>
    </div>
    <div class="text-center mt-2">
        <a href="/{{ lang }}/features/" class="btn btn-outline-primary rounded-pill px-4">Discover all features</a>
    </div>
</div>

<div class="bg-body-tertiary py-5 border-top border-bottom">
    <div class="container">
        <div class="row align-items-center py-4">
            <div class="col-lg-8 text-center text-lg-start mb-4 mb-lg-0">
                <span class="badge bg-primary-subtle text-primary border border-primary-subtle rounded-pill mb-2 px-3 py-2 fw-semibold">Free Tool</span>
                <h2 class="fw-bold mb-3 display-6">{{ translations[lang].generatorTitle }}</h2>
                <p class="lead text-muted mb-0 fs-5">{{ translations[lang].generatorDesc }}</p>
            </div>
            <div class="col-lg-4 text-center text-lg-end">
                <a href="https://generator.myclubshot.de" target="_blank" rel="noopener" class="btn btn-primary btn-lg rounded-pill px-5 py-3 shadow-sm fw-semibold">
                    {{ translations[lang].generatorCta }} ↗
                </a>
            </div>
        </div>
    </div>
</div>

<div class="bg-body py-5 border-bottom">
    <div class="container">
        <div class="row align-items-center py-4 flex-row-reverse">
            <div class="col-lg-8 text-center text-lg-start mb-4 mb-lg-0 ps-lg-5">
                <span class="badge bg-danger rounded-pill mb-2 px-3 py-2 fw-semibold">{{ translations[lang].timerComingSoon }}</span>
                <h2 class="fw-bold mb-3 display-6">{{ translations[lang].timerHighlightTitle }}</h2>
                <p class="lead text-muted mb-4 fs-5">{{ translations[lang].timerHighlightDesc }}</p>
                <div class="d-flex flex-wrap justify-content-center justify-content-lg-start gap-3">
                    <a href="/{{ lang }}/training-timer/" class="btn btn-outline-primary btn-lg rounded-pill px-4 py-2 fs-6 fw-semibold">
                        Learn More
                    </a>
                </div>
            </div>
            <div class="col-lg-4 text-center">
                <div class="p-5 bg-body-tertiary rounded-4 border shadow-sm d-inline-block">
                    <span class="fs-1">⏱️</span>
                    <h3 class="fs-4 mt-3 mb-1">Clubshot App</h3>
                    <p class="text-muted small mb-0">Coming Soon for Android</p>
                </div>
            </div>
        </div>
    </div>
</div>